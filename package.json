{
  "name": "odin-connect",
  "version": "1.4.1",
  "description": "",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "demo:update": "npm run build && cd demo && npm install ../ && cd ..",
    "demo:start": "cd demo && npm run dev",
    "demo:build": "npm run demo:update && cd demo && npm run build",
    "demo": "npm run demo:update && npm run demo:start",
    "release": "release-it"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Toniq-Labs/odin-connect.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Toniq-Labs/odin-connect/issues"
  },
  "homepage": "https://github.com/Toniq-Labs/odin-connect#readme",
  "devDependencies": {
    "@types/node": "^24.3.1",
    "@vitest/ui": "^3.2.6",
    "jsdom": "^27.0.0",
    "release-it": "^19.0.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@apimatic/json-bigint": "^1.2.0",
    "@dfinity/identity": "^3.4.3",
    "axios": "^1.12.0"
  },
  "overrides": {
    "undici": "6.24.1",
    "esbuild": "0.28.1"
  },
  "release-it": {
    "npm": {
      "publish": true
    },
    "git": {
      "commitMessage": "chore: release v${version}",
      "tagName": "v${version}"
    }
  }
}
